{
	"name": "@vozka/core",
	"version": "0.0.1",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/contember/vozka.git",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"vozka": "./src/cli.ts"
	},
	"files": [
		"src",
		"!src/**/__tests__/**"
	],
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@vozka/config": "workspace:*"
	},
	"peerDependencies": {
		"@propustka/client": "^0.0.5",
		"oblaka-iac": "*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251001.0",
		"@propustka/client": "^0.0.5",
		"@types/bun": "latest",
		"oblaka-iac": "latest",
		"wrangler": "4.72.0"
	}
}
