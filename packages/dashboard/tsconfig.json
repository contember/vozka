{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"noEmit": true,
		"declaration": false,
		"declarationMap": false,
		"allowImportingTsExtensions": false
	},
	"include": ["src/**/*", "vite.config.ts"],
	// Tests run under `bun test` (which provides `bun:test`'s ambient types). They're excluded from
	// the SPA's tsc program so the browser build's `types: ["vite/client"]` stays pure — pulling in
	// `@types/bun` just to resolve `bun:test` would leak Node/Bun globals into the client code.
	"exclude": ["src/**/__tests__/**"]
}
