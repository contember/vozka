	},
	"dependencies": {
		"@vozka/core": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251001.0",
		"@types/bun": "latest",
		"lopata": "latest",
		"oblaka-iac": "latest",
		"wrangler": "^4.24.0"
	}
}
