{
	"name": "@vozka/worker",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
