{
	"name": "@vozka/worker",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"dev": "bunx lopata dev --env local --port 18291 --listen 0.0.0.0",
		"oblaka": "bunx oblaka oblaka.ts",
		"oblaka:deploy": "bunx oblaka oblaka.ts --remote",
		"bootstrap": "bun run scripts/bootstrap.ts",
		"seed": "bun run scripts/seed.ts"
	},
	"dependencies": {
		"@cloudflare/containers": "^0.0.30",
		"@propustka/client": "^0.0.5",
		"vozka-config": "workspace:*",
		"@vozka/core": "workspace:*",
		"@vozka/runner": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251001.0",
		"@types/bun": "latest",
		"lopata": "latest",
		"oblaka-iac": "^0.0.18",
		"wrangler": "^4.24.0"
	}
}
